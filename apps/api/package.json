{
  "name": "api",
  "version": "1.0.0",
  "description": "Wardrobe backend bootstrap service",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "test": "pnpm run test:bootstrap && pnpm run test:env && pnpm run test:dynamodb",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc --outDir dist",
    "typecheck": "tsc --noEmit",
    "test:bootstrap": "node scripts/check-bootstrap-spec.mjs",
    "test:directory-structure": "node scripts/check-directory-structure-spec.mjs",
    "test:env": "node --import tsx/esm scripts/check-env-spec.mjs",
    "test:dynamodb": "node --import tsx/esm scripts/check-dynamodb-client-spec.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "dependencies": {
    "dotenv": "^17.2.3",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
